---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AgeGate from '../components/AgeGate.astro';
import LeftSkyscraper from '../components/ads/LeftSkyscraper.astro';
import RightSkyscraper from '../components/ads/RightSkyscraper.astro';
import '../styles/global.css';

const SITE_NAME = 'CashKompass';
const SITE_URL = Astro.site?.href?.replace(/\/$/, '') ?? 'https://affiliate-site.michaelhardi97.workers.dev';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  canonicalURL?: string;
  pubDate?: Date;
  author?: string;
  /** Single JSON-LD object or array → rendered as @graph if array */
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  image = '/og-default.jpg',
  type = 'website',
  canonicalURL = Astro.url.href,
  pubDate,
  author,
  schema,
} = Astro.props;

const ogImage = new URL(image, SITE_URL).href;

// Wrap array in @graph, keep single objects as-is
const schemaBlock = schema
  ? (Array.isArray(schema)
      ? { '@context': 'https://schema.org', '@graph': schema }
      : schema)
  : null;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Open Graph -->
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="de_DE" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {type === 'article' && pubDate && (
      <meta property="article:published_time" content={pubDate.toISOString()} />
    )}
    {type === 'article' && author && (
      <meta property="article:author" content={author} />
    )}

    {schemaBlock && (
      <script type="application/ld+json" set:html={JSON.stringify(schemaBlock)} />
    )}

    <script defer src="https://cloud.umami.is/script.js" data-website-id="bf5f73d5-9c85-4fca-9d5c-4cf0d6d9ee3f"></script>
  </head>
  <body>
    <AgeGate />
    <div class="site-wrapper">
      <Header />
      <div class="sky-layout">
        <aside class="sky-aside sky-aside--left">
          <LeftSkyscraper />
        </aside>
        <main class="sky-main">
          <slot />
        </main>
        <aside class="sky-aside sky-aside--right">
          <RightSkyscraper />
        </aside>
      </div>
      <Footer />
    </div>
  </body>
</html>
