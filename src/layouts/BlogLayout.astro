---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SidebarAd from '../components/ads/SidebarAd.astro';
import InContentAd from '../components/ads/InContentAd.astro';

const SITE_URL = Astro.site?.href?.replace(/\/$/, '') ?? 'https://affiliate-site.michaelhardi97.workers.dev';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author?: string;
  image?: string;
  imageAlt?: string;
  tags?: string[];
}

const { title, description, pubDate, updatedDate, author, image, imageAlt, tags } = Astro.props;

const dateFormatter = new Intl.DateTimeFormat('de-DE', { dateStyle: 'long' });

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Startseite', item: SITE_URL + '/' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: SITE_URL + '/blog' },
    { '@type': 'ListItem', position: 3, name: title },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  type="article"
  pubDate={pubDate}
  author={author}
  schema={breadcrumbSchema}
>
  <div class="container">
    <Breadcrumb items={[
      { label: 'Startseite', href: '/' },
      { label: 'Blog', href: '/blog' },
      { label: title },
    ]} />

    <div class="content-grid">
      <article>
        <header class="article-header">
          <h1>{title}</h1>
          <div class="article-meta">
            {author && <span>von {author}</span>}
            <time datetime={pubDate.toISOString()}>
              {dateFormatter.format(pubDate)}
            </time>
            {updatedDate && (
              <span>
                Aktualisiert: <time datetime={updatedDate.toISOString()}>{dateFormatter.format(updatedDate)}</time>
              </span>
            )}
          </div>
          {tags && tags.length > 0 && (
            <ul class="tag-list">
              {tags.map((tag) => <li><span class="tag">{tag}</span></li>)}
            </ul>
          )}
        </header>

        <div class="article-body">
          <slot />
          <InContentAd />
        </div>
      </article>

      <aside class="sidebar">
        <SidebarAd />
        <div class="sidebar-widget">
          <div class="sidebar-widget-title">Mehr entdecken</div>
          <div class="sidebar-widget-body">
            <p style="font-size:0.875rem;color:var(--color-text-muted);margin-bottom:0.75rem;">
              Alle Reviews und Vergleiche auf einen Blick.
            </p>
            <a href="/reviews" class="affiliate-link" style="width:100%;justify-content:center;text-decoration:none;">
              Zu den Reviews
            </a>
          </div>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
