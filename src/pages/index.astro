---
import BaseLayout from '../layouts/BaseLayout.astro';
import AffiliateLink from '../components/AffiliateLink.astro';
import Rating from '../components/Rating.astro';
import { getCollection } from 'astro:content';

const reviews = (await getCollection('reviews'))
  .filter((r) => r.data.category === 'reward-apps')
  .sort((a, b) => b.data.rating - a.data.rating);

const blogPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const dateFormatter = new Intl.DateTimeFormat('de-DE', { dateStyle: 'medium' });

const siteUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://affiliate-site.michaelhardi97.workers.dev';
const globalSchemas = [
  {
    '@type': 'Organization',
    name: 'CashKompass',
    url: siteUrl,
    description: 'Unabhängige Reviews und Guides zu Reward-Apps und seriösem Nebenverdienst',
  },
  {
    '@type': 'WebSite',
    name: 'CashKompass',
    url: siteUrl,
    description: 'Dein Kompass für seriösen Nebenverdienst',
  },
];
---

<BaseLayout
  title="CashKompass – Dein Kompass für seriösen Nebenverdienst"
  description="CashKompass testet und bewertet die besten Reward-Apps. Ehrliche Reviews zu FreeCash, Swagbucks und BigCash – mit konkreten Zahlen zu Verdienst und Auszahlung."
  schema={globalSchemas}
>
  <!-- ── Hero ──────────────────────────────────────── -->
  <section class="hero">
    <div class="hero__inner container">
      <div class="hero__content">
        <span class="hero__badge">Reward-Apps 2026</span>
        <h1 class="hero__headline">
          Dein Kompass für<br/>
          <span class="hero__headline-accent">seriösen Nebenverdienst</span>
        </h1>
        <p class="hero__subtitle">
          Wir testen die besten Reward-Apps – ehrlich, unabhängig und mit konkreten Zahlen.
          Finde heraus, welche App sich für dich wirklich lohnt.
        </p>
        <div class="hero__actions">
          <a href="/beste-reward-apps-2026" class="btn btn--primary">
            Beste Apps 2026
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/wie-wir-testen" class="btn btn--ghost-white">Wie wir testen</a>
        </div>
      </div>

      <!-- Kompass-Dekoration -->
      <div class="hero__visual" aria-hidden="true">
        <svg viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="200" cy="200" r="190" stroke="white" stroke-width="1.5"/>
          <circle cx="200" cy="200" r="150" stroke="white" stroke-width="1"/>
          <circle cx="200" cy="200" r="100" stroke="white" stroke-width="0.75"/>
          <circle cx="200" cy="200" r="50"  stroke="white" stroke-width="0.5"/>
          <!-- Kreuzlinien -->
          <line x1="200" y1="10" x2="200" y2="390" stroke="white" stroke-width="1"/>
          <line x1="10" y1="200" x2="390" y2="200" stroke="white" stroke-width="1"/>
          <line x1="66" y1="66" x2="334" y2="334" stroke="white" stroke-width="0.5"/>
          <line x1="334" y1="66" x2="66" y2="334" stroke="white" stroke-width="0.5"/>
          <!-- Nord-Nadel -->
          <polygon points="200,20 218,200 200,168 182,200" fill="#F5A623"/>
          <!-- Süd-Nadel -->
          <polygon points="200,380 182,200 200,232 218,200" fill="white" fill-opacity="0.6"/>
          <!-- Ost-Zacke -->
          <polygon points="380,200 200,182 232,200 200,218" fill="white" fill-opacity="0.4"/>
          <!-- West-Zacke -->
          <polygon points="20,200 200,218 168,200 200,182" fill="white" fill-opacity="0.4"/>
          <!-- Zentrum -->
          <circle cx="200" cy="200" r="12" fill="white" fill-opacity="0.3"/>
          <circle cx="200" cy="200" r="6"  fill="#F5A623"/>
          <!-- N-Markierung -->
          <text x="188" y="10" font-size="20" font-weight="bold" fill="white" fill-opacity="0.8">N</text>
        </svg>
      </div>
    </div>
  </section>

  <!-- ── Top Reward-Apps ───────────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2>Top Reward-Apps im Test</h2>
        <p>Alle Apps von uns getestet, mit echten Zahlen zu Verdienst, Auszahlung und Seriosität.</p>
      </div>
      <div class="app-grid">
        {reviews.map((review) => (
          <div class="app-card">
            <div>
              <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:.5rem;margin-bottom:.4rem;">
                <p class="app-card__name">{review.data.providerName}</p>
                <span class="category-badge category-badge--reward-apps">Reward-App</span>
              </div>
              <Rating value={review.data.rating} />
            </div>
            <p class="app-card__desc">{review.data.description}</p>
            <div class="app-card__bonus">
              <span class="app-card__bonus-label">Bonus</span>
              <span class="app-card__bonus-value">{review.data.bonus}</span>
            </div>
            <div class="app-card__actions">
              <a href={`/reviews/${review.slug}`} class="btn btn--ghost" style="flex:1;">
                Zum Review
              </a>
              <AffiliateLink slug={review.data.affiliateSlug}>
                Jetzt testen
              </AffiliateLink>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Warum CashKompass ─────────────────────────── -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__header">
        <h2>Warum CashKompass?</h2>
        <p>Keine Werbung als Ratschlag. Wir testen selbst und sagen dir, was wirklich drin ist.</p>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:1.5rem;">
        {([
          {
            title: 'Ehrliche Orientierung',
            text: 'Realistische Einordnung ohne aufgeblasene Verdienstversprechen.',
            svg: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg>`,
          },
          {
            title: 'Selbst getestet',
            text: 'Jede App wird von uns selbst genutzt, bevor wir sie empfehlen.',
            svg: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>`,
          },
          {
            title: 'Aktuelle Daten',
            text: 'Auszahlungsschwellen und Methoden werden regelmäßig geprüft.',
            svg: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>`,
          },
          {
            title: 'Transparent',
            text: 'Affiliate-Links sind klar gekennzeichnet. Deine Kosten ändern sich nicht.',
            svg: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>`,
          },
        ] as { title: string; text: string; svg: string }[]).map((item) => (
          <div class="feature-card">
            <div class="feature-card__icon" set:html={item.svg} />
            <h3 class="feature-card__title">{item.title}</h3>
            <p class="feature-card__text">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Blog-Vorschau ─────────────────────────────── -->
  {blogPosts.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section__header">
          <h2>Aktuelle Beiträge</h2>
          <p>Guides, Vergleiche und Tipps rund ums Nebenverdienen.</p>
        </div>
        <div class="blog-grid">
          {blogPosts.map((post) => (
            <article class="card">
              <div class="card-body">
                {post.data.tags && (
                  <ul class="tag-list" style="margin-bottom:.4rem;">
                    {post.data.tags.slice(0, 2).map((tag) => (
                      <li><span class="tag">{tag}</span></li>
                    ))}
                  </ul>
                )}
                <h3 class="card-title">
                  <a href={`/blog/${post.slug}`}>{post.data.title}</a>
                </h3>
                <p class="card-description">{post.data.description}</p>
                <p class="card-meta">
                  <time datetime={post.data.pubDate.toISOString()}>
                    {dateFormatter.format(post.data.pubDate)}
                  </time>
                  {post.data.author && <span> · {post.data.author}</span>}
                </p>
              </div>
            </article>
          ))}
        </div>
        <div style="text-align:center;margin-top:2rem;">
          <a href="/blog" class="btn btn--ghost">Alle Beiträge ansehen</a>
        </div>
      </div>
    </section>
  )}
</BaseLayout>
