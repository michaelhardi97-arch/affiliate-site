---
interface Props {
  pros: string[];
  cons: string[];
  prosLabel?: string;
  consLabel?: string;
}
const { pros, cons, prosLabel = 'Vorteile', consLabel = 'Nachteile' } = Astro.props;
---

<div class="pros-cons">
  <div class="pros-cons__col pros-cons__col--pros">
    <h3 class="pros-cons__heading pros-cons__heading--pros">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <polyline points="20 6 9 17 4 12"/>
      </svg>
      {prosLabel}
    </h3>
    <ul class="pros-cons__list">
      {pros.map((item) => <li>{item}</li>)}
    </ul>
  </div>
  <div class="pros-cons__col pros-cons__col--cons">
    <h3 class="pros-cons__heading pros-cons__heading--cons">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
      {consLabel}
    </h3>
    <ul class="pros-cons__list">
      {cons.map((item) => <li>{item}</li>)}
    </ul>
  </div>
</div>
